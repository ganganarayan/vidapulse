# ============================================================
# VIDAPULSE BACKEND — Environment Variables
#
# HOW TO USE:
#   Development : Copy this file to backend/.env and fill in values.
#                 NEVER commit .env to git.
#   Railway     : Set these in Railway → Service → Variables.
#                 Railway auto-injects DATABASE_URL — no need to set it manually.
# ============================================================

# ── Server ────────────────────────────────────────────────
# Railway: set to "production"
NODE_ENV=development

# Railway: Railway assigns this automatically. Do NOT set in Railway variables.
# Development: any unused port (3000 is the default fallback).
PORT=3000

# The public URL of the app subdomain — used in OAuth redirects and reset-password links.
# Railway production value: https://app.vidapulse.io
APP_URL=http://localhost:3000

# Log verbosity: error | warn | info | debug
# Railway: set to "info" (or "warn" to reduce noise)
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────
# Railway: Railway injects this automatically when you attach a Postgres plugin.
#          Do NOT override it in Railway Variables — Railway owns this value.
# Format:  postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/vidapulse

# ── Security ──────────────────────────────────────────────
# Shared secret between divineleads.guru and this server (validates incoming webhooks).
# Must match the secret configured in the divineleads webhook settings.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=replace-with-a-32-byte-hex-secret

# Secret for signing JWTs (auth tokens for logged-in users).
# Must be long, random, and never shared. Rotate only during a planned maintenance window
# (all active sessions will be invalidated when this changes).
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-another-32-byte-hex-secret

# How long JWT access tokens last before the user must log in again.
# Supported formats: "7d" (days), "24h" (hours), "1h" (hour).
JWT_EXPIRES_IN=7d

# ── OAuth — Google + Microsoft Login ─────────────────────
# Required for social login buttons to appear on the login page.
# Leave blank if testing email/password only — OAuth buttons are hidden when not configured.
#
# Google Cloud Console: https://console.cloud.google.com → APIs & Services → Credentials
#   → OAuth 2.0 Client IDs → Authorised redirect URIs:
#      https://app.vidapulse.io/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Microsoft OAuth — reserved for future use, not active yet.

# ── Railway Deployment Checklist ─────────────────────────
# Required Railway Variables (set in Railway → Service → Variables):
#   NODE_ENV          → production
#   APP_URL           → https://app.vidapulse.io
#   LOG_LEVEL         → info
#   WEBHOOK_SECRET    → (generate with command above)
#   JWT_SECRET        → (generate with command above)
#   JWT_EXPIRES_IN    → 7d
#   GOOGLE_CLIENT_ID  → (from Google Cloud Console)
#   GOOGLE_CLIENT_SECRET → (from Google Cloud Console)
#
#   DATABASE_URL is auto-injected by Railway — do NOT set it manually.
#   PORT             is auto-assigned by Railway — do NOT set it manually.
#
# Start command (railway.json): cd backend && npm run start:production
#   → Boots index.js which runs pending DB migrations FIRST, then starts the server.
#   → No separate migration step needed before deploy.
#
# Health check: GET /api/health (returns 200 healthy / 503 degraded)
#   → Configured in railway.json as healthcheckPath.
#   → Returns DB connectivity status and uptime.
#
# Notes:
#   - VidaPulse does NOT send emails directly.
#     All subscriber emails (welcome, password reset) are sent by divineleads.guru
#     after receiving the corresponding behavioral webhook events.
#   - The outbound webhook URL (where events are sent to divineleads) is stored
#     in the webhook_settings database table — set via the Admin → Webhooks page,
#     not via env vars.
